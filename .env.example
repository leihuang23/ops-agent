POSTGRES_DB=ops_agent
POSTGRES_USER=ops_agent
POSTGRES_PASSWORD=ops_agent
APP_ENV=demo
DATABASE_URL=postgresql+psycopg://ops_agent:ops_agent@postgres:5432/ops_agent
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000
ALLOW_UNSAFE_BOOTSTRAP_SEED=false
LOG_LEVEL=INFO
LOG_FORMAT=text
API_INTERNAL_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hashing-v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30
DOCUMENT_INGEST_TOKEN=
EVAL_RUN_TOKEN=
DEMO_OPERATOR_TOKEN=
OPERATOR_UI_ENABLED=true
OBSERVABILITY_PROVIDER=auto
OBSERVABILITY_FULL_PAYLOADS=false
OBSERVABILITY_TIMEOUT_SECONDS=2
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROJECT_ID=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=ops-agent-local
LANGSMITH_WEB_URL=https://smith.langchain.com
RATE_LIMIT_MUTATIONS_PER_MINUTE=10
RATE_LIMIT_SEARCH_PER_MINUTE=60
