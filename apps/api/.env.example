APP_NAME=ops-agent-api
APP_ENV=local
APP_VERSION=0.1.0
DATABASE_URL=postgresql+psycopg://ops_agent:ops_agent@localhost:5432/ops_agent
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000
ALLOW_UNSAFE_BOOTSTRAP_SEED=false
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hashing-v1
DOCUMENT_INGEST_TOKEN=
EVAL_RUN_TOKEN=
DEMO_OPERATOR_TOKEN=
OBSERVABILITY_PROVIDER=auto
OBSERVABILITY_FULL_PAYLOADS=false
OBSERVABILITY_TIMEOUT_SECONDS=2
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROJECT_ID=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=ops-agent-local
LANGSMITH_WEB_URL=https://smith.langchain.com

# LLM configuration
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
LOG_FORMAT=text
RATE_LIMIT_MUTATIONS_PER_MINUTE=10
RATE_LIMIT_SEARCH_PER_MINUTE=60
